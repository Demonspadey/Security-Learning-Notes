习题2：requests基础巩固
# 导入库 + 发送基础GET请求，查看状态码
import requests

url = "http://httpbin.org/get"
res = requests.get(url)
print("响应状态码：", res.status_code)

习题3：SQL注入请求模拟
# 用requests带注入参数发起请求，观察响应
import requests

# 构造带单引号闭合的注入参数
url = "http://httpbin.org/get?id=1'"
res = requests.get(url)

# 打印响应长度，简单判断是否异常
print("响应内容长度：", len(res.text))
