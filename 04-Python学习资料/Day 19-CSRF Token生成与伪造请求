### 第1题：CSRF Token生成与校验脚本
```python
# 导入随机数、字符串模块，用于生成随机Token
import random
import string

def generate_csrf_token(length: int = 32) -> str:
    """
    生成随机、安全的CSRF Token
    :param length: Token长度，默认32位
    :return: 生成的CSRF Token字符串
    """
    # 定义Token字符集：大小写字母+数字，保证随机性和复杂度
    chars = string.ascii_letters + string.digits
    # 随机选择指定长度字符拼接为Token
    token = ''.join(random.choice(chars) for _ in range(length))
    return token

def validate_csrf_token(user_token: str, server_token: str) -> bool:
    """
    校验客户端提交的Token与服务端存储的Token是否一致
    :param user_token: 前端请求携带的Token
    :param server_token: 服务端会话存储的合法Token
    :return: 校验结果，True为通过，False为拦截
    """
    # 严格比对两个Token字符串，完全一致则校验通过
    return user_token == server_token

# 脚本测试入口
if __name__ == "__main__":
    # 服务端生成合法Token
    server_token = generate_csrf_token()
    print(f"服务端生成合法CSRF Token：{server_token}")
    
    # 模拟前端提交合法Token
    valid_token = server_token
    print(f"合法Token校验结果：{validate_csrf_token(valid_token, server_token)}")
    
    # 模拟前端提交伪造Token
    invalid_token = generate_csrf_token()
    print(f"伪造Token校验结果：{validate_csrf_token(invalid_token, server_token)}")

### 第2题：请求来源Referer校验脚本
def check_referer(referer: str, valid_domains: list) -> bool:
    """
    校验请求来源Referer是否为合法域名，防御CSRF跨源请求
    :param referer: 请求头中的Referer字段值
    :param valid_domains: 合法来源域名列表
    :return: 校验结果，True为合法来源，False为非法来源
    """
    # 处理Referer为空的情况：直接判定为非法请求，拦截处理
    if not referer:
        return False
    
    # 遍历合法域名列表，判断Referer是否包含合法域名
    for domain in valid_domains:
        if domain in referer:
            return True
    # 无匹配合法域名，判定为非法跨源请求
    return False

# 脚本测试入口
if __name__ == "__main__":
    # 定义业务合法来源域名
    valid_domains = ["https://www.target-site.com", "https://m.target-site.com"]
    
