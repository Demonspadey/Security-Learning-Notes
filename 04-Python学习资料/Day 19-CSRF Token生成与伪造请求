### 第3题：requests联动模拟CSRF攻击与防护验证
import requests
def simulate_csrf_attack(target_url:str,user_cookie:dict,payload:dict) -> requests.Response:
    """
    模拟无Token防护的CSRF攻击:携带用户Cookie发送伪造请求
    :param target_url: 目标站点操作接口地址
    :param user_cookie: 用户登录后的会话Cookie
    :param payload: 伪造的操作请求参数
    :return: 接口响应结果
    """
    response=requests.post(url=target_url,cookies=user_cookie,data=payload)
    return response
def simulate_csrf_with_token(target_url:str,user_cookie:dict,payload:dict,csrf_token:str) -> requests.Response:
    """
    模拟带Token防护的CSRF攻击:携带合法Token才可请求成功
    :param target_url: 目标站点操作接口地址
    :param user_cookie: 用户登录后的会话Cookie
    :param payload: 业务请求参数
    :param csrf_token: 服务端生成的合法CSRFa Token
    :return: 接口响应结果
    """
    payload["csrf_token"]=csrf_token
    response=requests.post(url=target_url,cookies=user_cookie,data=payload)
    return response
