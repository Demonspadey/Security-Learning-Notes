### 题2：RSA数字签名&验签模拟（🟡 理解）
import hashlib

def create_sign(msg, d, n):
    """
    生成数字签名：发送方用自身私钥签名
    :param msg: 原始消息字符串
    :param d: 发送方私钥指数
    :param n: 模数
    :return: 签名值、原始哈希值
    """
    # 1. 对消息生成SHA256哈希摘要
    hash_hex = hashlib.sha256(msg.encode("utf-8")).hexdigest()
    # 十六进制转整数，用于模幂运算
    hash_val = int(hash_hex, 16) % n
    # 2. 私钥加密哈希摘要，生成签名
    sign = pow(hash_val, d, n)
    return sign, hash_val

def check_sign(msg, sign, e, n):
    """
    验证数字签名：接收方用发送方公钥验签
    :param msg: 接收的消息字符串
    :param sign: 接收的签名值
    :param e: 发送方公钥指数
    :param n: 模数
    :return: 验签是否通过
    """
    # 1. 对接收的消息重新计算哈希
    new_hash_hex = hashlib.sha256(msg.encode("utf-8")).hexdigest()
    new_hash = int(new_hash_hex, 16) % n
    # 2. 公钥解密签名，得到原始哈希
    old_hash = pow(sign, e, n)
    # 3. 对比两个哈希值
    return new_hash == old_hash

# 场景测试
if __name__ == "__main__":
    # 测试用RSA参数（仅演示，真实场景用2048位以上密钥）
    n, e, d = 3337, 3, 2147
    original_msg = "项目安全合规审核通过"
    tamper_msg = "项目安全合规审核不通过"

    # 发送方生成签名
    sign, _ = create_sign(original_msg, d, n)
    print(f"原始报文签名值：{sign}")

    # 正常报文验签
    normal_result = "✅ 通过" if check_sign(original_msg, sign, e, n) else "❌ 失败"
    print(f"正常报文验签结果：{normal_result}")

    # 篡改报文验签
    tamper_result = "✅ 通过" if check_sign(tamper_msg, sign, e, n) else "❌ 失败"
    print(f"篡改报文验签结果：{tamper_result}")
