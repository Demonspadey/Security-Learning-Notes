### 题1：RSA完整密钥生成+加解密工具（🔴 必抄）
功能：对接软考RSA计算考点，输出标准得分步骤，支持加解密验证
```python
def rsa_full_calc(p, q, e, msg):
    """
    RSA完整计算流程：密钥生成 + 加密 + 解密验证
    :param p: 大质数p
    :param q: 大质数q
    :param e: 公钥指数e
    :param msg: 明文数值
    """
    # 1. 计算核心参数
    n = p * q
    phi_n = (p - 1) * (q - 1)
    # pow三参数形式直接计算模逆元
    d = pow(e, -1, phi_n)

    # 输出标准考试步骤
    print("===== RSA密钥计算得分步骤 =====")
    print(f"1. 模数 n = {p} × {q} = {n}")
    print(f"2. 欧拉值 φ(n) = {p-1} × {q-1} = {phi_n}")
    print(f"3. 私钥 d = {d}")
    print(f"公钥 (n,e) = ({n}, {e})")
    print(f"私钥 (n,d) = ({n}, {d})")

    # 2. 公钥加密
    cipher = pow(msg, e, n)
    # 3. 私钥解密
    plain = pow(cipher, d, n)

    print("\n===== 加解密验证 =====")
    print(f"明文：{msg}")
    print(f"加密密文：{cipher}")
    print(f"解密还原：{plain}")
    print(f"验证结果：{'✅ 一致' if plain == msg else '❌ 错误'}")

# 真题参数测试
