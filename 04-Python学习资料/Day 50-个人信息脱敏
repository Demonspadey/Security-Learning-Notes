## 3. 脚本三：正则实现手机号掩码（🔴 必抄）  
导入正则模块
import re

# 原始手机号
phone_num = "13812345678"
# 正则分组：匹配前3位、中间4位、后4位数字
pattern = r"(\d{3})\d{4}(\d{4})"
# 替换中间4位为****，\1 \2 引用分组内容
result = re.sub(pattern, r"\1****\2", phone_num)

print(f"脱敏后手机号：{result}")
