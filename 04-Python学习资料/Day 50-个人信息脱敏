功能：姓名、手机号、身份证基础脱敏
```python
def anonymize(name,id_num,phone):
    anon_name=name[0]+"**"
    anon_id=id_num[-4:] if len(id_num) >=4 else id_num
    anon_phone=phone[-4:] if len(phone) >=4 else phone
    return anon_name,anon_id,anon_phone
if __name__ == "__main__":
    name,id_num,phone="张三","1101119900307663x","13812345678"
    res=anonymize(name,id_num,phone)
    print(f"匿名化结果：{res}")

