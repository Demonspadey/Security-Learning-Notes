第3题：模拟注释符截断 + 危险字符特征检测
# 模拟注释符截断 + 危险字符特征检测
user_input = input("请输入用户名：")
sql = f"SELECT * FROM users WHERE username = '{user_input}' AND active=1"
print("生成的SQL语句：", sql)

# 危险字符集（对应注释符、堆叠注入分号等危险特征）
danger_chars = ["--", ";", "/*", "*/"]
has_danger = any(char in user_input for char in danger_chars)
if has_danger:
    print("⚠️ 检测到可疑字符（注释符或分号），可能存在注入风险")
else:
    print("✅ 输入未发现明显危险特征")
