## 第3题：判断字符串是否包含关键字

url=input("请输入待检测URL:")
key_list=["'","union","select","and","or"]
has_inject=False
for key in key_list:
  if key in url.lower():
    has_inject=True
    break
if has_inject:
  print("检测到疑似SQL注入特征")
else:
  print("无明显注入特征")
