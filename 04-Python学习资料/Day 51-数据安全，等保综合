### 5. 等级判定：等保系统自动定级
def level_determine(object_type, damage):
    """
    等保定级自动判定
    object_type：1=公民个人 2=社会秩序 3=国家安全
    damage：1=一般 2=严重 3=特别严重
    """
    if object_type == 1:
        return 1 if damage <= 2 else 2
    elif object_type == 2:
        if damage == 1:
            return 2
        elif damage == 2:
            return 3
        else:
            return 4
    else:
        if damage == 1:
            return 3
        elif damage == 2:
            return 4
        else:
            return 5

# 测试：社会秩序+严重损害
print(f"系统保护等级：{level_determine(2, 2)}级")
