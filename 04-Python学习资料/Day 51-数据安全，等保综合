### 1. 时间差计算：MTTD/MTTR/RTO/RPO 自动核算
```python
from datetime import datetime

def calc_security_time(attack_time, detect_time, recover_time, fmt="%Y-%m-%d %H:%M:%S"):
    """
    计算MTTD、MTTR、事件总时长
    入参：攻击发生时间、发现时间、恢复时间
    """
    # 字符串转时间对象
    t_attack = datetime.strptime(attack_time, fmt)
    t_detect = datetime.strptime(detect_time, fmt)
    t_recover = datetime.strptime(recover_time, fmt)

    # 计算MTTD：攻击发生→发现
    mttd = (t_detect - t_attack).total_seconds() / 60
    # 计算MTTR：发现→业务恢复
    mttr = (t_recover - t_detect).total_seconds() / 60
    # 事件总时长
    total = (t_recover - t_attack).total_seconds() / 60

    print(f"MTTD = {mttd:.0f} 分钟")
    print(f"MTTR = {mttr:.0f} 分钟")
    print(f"事件总时长 = {total:.0f} 分钟")
    return mttd, mttr, total

### 2. 数据脱敏：字符串切片基础脱敏
def basic_desensitize(name, phone, id_card):
    """姓名、手机号、身份证基础脱敏（去标识化）"""
    # 姓名留姓氏，其余隐藏
    new_name = name[0] + "**"
    # 手机号保留后4位
    new_phone = phone[-4:]
    # 身份证保留后4位
    new_id = id_card[-4:]

    print(f"脱敏结果：{new_name} | {new_phone} | {new_id}")
    return new_name, new_phone, new_id

# 测试
