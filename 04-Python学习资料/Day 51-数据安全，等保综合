### 3. 正则脱敏：手机号掩码（对标sed正则逻辑
import re

def phone_mask(phone_num):
    """手机号中间四位掩码，对应Linux sed脱敏逻辑"""
    # 正则分组：前3位、中间4位、后4位
    pattern = r"(\d{3})\d{4}(\d{4})"
    # 替换中间四位为****
    result = re.sub(pattern, r"\1****\2", phone_num)
    return result

# 测试
print(phone_mask("13812345678"))

