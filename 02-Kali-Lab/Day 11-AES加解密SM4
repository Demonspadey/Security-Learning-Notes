# 创建测试文件
echo "国密SM4对称加密测试数据" > plain.txt

# AES-128-CBC加密（模拟SM4加密流程）
openssl enc -aes-128-cbc -in plain.txt -out cipher.bin \
  -K 00112233445566778899AABBCCDDEEFF \
  -iv 00000000000000000000000000000000

# 解密验证
openssl enc -d -aes-128-cbc -in cipher.bin -out decrypted.txt \
  -K 00112233445566778899AABBCCDDEEFF \
  -iv 00000000000000000000000000000000

cat decrypted.txt  # 输出原文
