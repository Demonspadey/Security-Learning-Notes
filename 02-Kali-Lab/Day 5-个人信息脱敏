# 任务1：创建测试用户数据文件
cat > /LLL/user_data.txt << EOF
张三,11010119900307663X,13812345678
李四,220102198505124321,15911112222
王五,370203199912311234,18888888888
EOF

# 任务2：sed正则脱敏手机号
sed -i -E 's([0-9]{3})[0-9]{4}([0-9]{4})(,?)$/\1****\2\3/g' /LLL/user_data.txt

# 查看脱敏后文件
cat /LLL/user_data.txt

# 任务3：perl 实现姓名匿名化
perl -CSD -F, -lane 'print substr($F[0],0,1) . "**," . $F[1] . "," . $F[2]' /LLL/user_data.txt   #防止乱码

-CSD：规避中文乱码 -F,：以逗号为分割符
